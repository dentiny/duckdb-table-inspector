# name: test/sql/inspect_database/inspect_database_restart.test
# description: Verify index_bytes is consistent after restart
# group: [inspect_database]

require table_inspector

load __TEST_DIR__/inspect_restart.db

statement ok
CREATE TABLE t (id INTEGER, val INTEGER);

statement ok
INSERT INTO t SELECT i, i FROM range(5000) t(i);

statement ok
CREATE INDEX idx_id ON t(id);

statement ok
CREATE INDEX idx_val ON t(val);

statement ok
CHECKPOINT;

# Save index_bytes before restart
statement ok
CREATE TABLE before_restart AS SELECT index_bytes FROM inspect_database() WHERE table_name = 't';

restart

# After restart, index_bytes should be the same
query I
SELECT (SELECT index_bytes FROM before_restart) = (SELECT index_bytes FROM inspect_database() WHERE table_name = 't');
----
true
